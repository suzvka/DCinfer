{
  "version": 3,
  "configurePresets": [
    {
      "name": "gcc-debug",
      "displayName": "GCC Linux Debug",
      "description": "Linux GCC + Ninja (Debug) — 需要 GCC ≥ 11",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-linux",
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON"
      }
    },
    {
      "name": "gcc-release",
      "displayName": "GCC Linux Release",
      "description": "Linux GCC + Ninja (Release) — 需要 GCC ≥ 11",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-linux",
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON"
      }
    }
  ]
}
