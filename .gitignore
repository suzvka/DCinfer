# .gitignore for a CMake-based C++ project
# Keep repository content focused on source, headers and documentation.

# Build directories
/build/
/bld/
/bin/
/lib/
/out/
/artifacts/

# CMake generated files and directories
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.cmake
CTestTestfile.cmake
Testing/

# Compiled object files, libraries, and executables
*.o
*.obj
*.lo
*.la
*.al
*.a
*.lib
*.dll
*.so
*.dylib
*.exe
*.out
*.app

# Debug and profiling files
*.pdb
*.ilk
*.prof
*.pgd

# Temporary and backup files
*.tmp
*.temp
*.log
*.swp
*~
*.bak
*.orig
*.rej

# Editor/IDE folders (local settings)
.vscode/
.vs/
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Cache and dependency directories
.cache/
*.cache
node_modules/

# Coverage and test artifacts
coverage/
coverage.*
*.gcda
*.gcno

# Generated documentation (if you produce docs during build)
docs/build/

# Keep source, headers, scripts and docs in repo. Exclude local build/IDE artifacts only.
